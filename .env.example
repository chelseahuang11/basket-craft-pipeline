# Remote MySQL source database (credentials shared by instructor)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Local Postgres container — must match docker-compose.yml
# Port 5433 is intentional (avoids collision with MP01 on port 5432)
PG_HOST=localhost
PG_PORT=5433
PG_DB=basket_craft
PG_USER=postgres
PG_PASSWORD=postgres
